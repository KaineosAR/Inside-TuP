Algoritmo ejercicio_1
	// Ejercicio 1Ḟ - Dados dos valores enteros A y B, informar la suma, la resta y el producto.
	Definir suma, resta, producto Como Entero;
	Definir A Como Entero;
	Definir B Como Entero;
	
	Escribir "Ingrese valor para A";
	Leer A;
	Escribir "Ingrese valor para B"
	Leer B;
	
	suma <- A + B;
	resta <- A - B;
	producto <- A * B;
	
	Escribir "Los resultados son:";
	Escribir "Suma = ",suma;
	Escribir "Resta = ",resta;
	Escribir "Producto = ",producto;
FinAlgoritmo